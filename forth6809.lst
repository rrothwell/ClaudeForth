                      (    forth6809.asm):00503         ; ============================================================
                      (    forth6809.asm):00504         ; SECTION 3: ACIA INTERRUPT HANDLER
                      (    forth6809.asm):00505         ; ============================================================
                      (    forth6809.asm):00506                  ORG   BASECODE       ; BASECODE is $E800. This ORG was missing
                      (    forth6809.asm):00507                                        ; entirely - every routine from here through
                      (    forth6809.asm):00508                                        ; SECTION 26 (IRQH, COLD/ABORT/QUIT, and
                      (    forth6809.asm):00509                                        ; every primitive) would otherwise have
                      (    forth6809.asm):00510                                        ; continued growing from wherever SECTION 2's
                      (    forth6809.asm):00511                                        ; WARM message left the location counter,
                      (    forth6809.asm):00512                                        ; inside INIT's 48-byte $FFC0-$FFEF budget,
                      (    forth6809.asm):00513                                        ; overflowing directly into VECTORS ($FFF0)
                      (    forth6809.asm):00514                                        ; instead of landing in BASECODE at all
                      (    forth6809.asm):00515         
                      (    forth6809.asm):00516         ; ------------------------------------------------------------
                      (    forth6809.asm):00517         ; INFILL - ( -- A=fill level, 0-63 ) input ring's current fill
                      (    forth6809.asm):00518         ; level. INBUFSZ is a power of two, and both indices are always
                      (    forth6809.asm):00519         ; kept in 0..INBUFSZ-1, so a plain masked subtraction gives the
                      (    forth6809.asm):00520         ; true mod-64 distance even across the wrap point.
                      (    forth6809.asm):00521         ; ------------------------------------------------------------
DFF4 B60106           (    forth6809.asm):00522         INFILL:  LDA   INHEAD
DFF7 B00107           (    forth6809.asm):00523                  SUBA  INTAIL
DFFA 843F             (    forth6809.asm):00524                  ANDA  #INBUFSZ-1
DFFC 39               (    forth6809.asm):00525                  RTS
                      (    forth6809.asm):00526         
                      (    forth6809.asm):00527         ; ------------------------------------------------------------
                      (    forth6809.asm):00528         ; RTSCHECKHI - called from IRQH's own RX path (interrupts
                      (    forth6809.asm):00529         ; already masked by hardware during ISR execution, so no
                      (    forth6809.asm):00530         ; explicit masking needed here). If the input ring has reached
                      (    forth6809.asm):00531         ; INHIWATER and RTS is not already asserted high, assert it -
                      (    forth6809.asm):00532         ; telling the remote device to pause sending. Per the 6850, RTS
                      (    forth6809.asm):00533         ; has no automatic tie to reception; this is ordinary firmware
                      (    forth6809.asm):00534         ; flow control, not a chip feature.
                      (    forth6809.asm):00535         ; ------------------------------------------------------------
DFFD BDDFF4           (    forth6809.asm):00536         RTSCHECKHI: JSR  INFILL
E000 8130             (    forth6809.asm):00537                     CMPA #INHIWATER
E002 250D             (    forth6809.asm):00538                     BLO  RTSCHIDONE
E004 0DFF             (    forth6809.asm):00539                     TST  RTSSTATE
E006 2609             (    forth6809.asm):00540                     BNE  RTSCHIDONE       ; already high - nothing to do
E008 86D5             (    forth6809.asm):00541                     LDA  #CR_RTSHI
E00A B7C008           (    forth6809.asm):00542                     STA  ACIACR
E00D 8601             (    forth6809.asm):00543                     LDA  #1
E00F 97FF             (    forth6809.asm):00544                     STA  RTSSTATE
E011 39               (    forth6809.asm):00545         RTSCHIDONE: RTS
                      (    forth6809.asm):00546         
                      (    forth6809.asm):00547         ; ------------------------------------------------------------
                      (    forth6809.asm):00548         ; RTSCHECKLO - called from mainline code (KEY), NOT from the
                      (    forth6809.asm):00549         ; ISR, so it must mask IRQ around its critical section: IRQH's
                      (    forth6809.asm):00550         ; own TXOFF path also writes ACIACR, and an interrupt landing
                      (    forth6809.asm):00551         ; mid-decision here could otherwise race it. If the ring has
                      (    forth6809.asm):00552         ; drained to INLOWATER or below and RTS is currently high,
                      (    forth6809.asm):00553         ; reassert RTS low - restoring TX-interrupt-enable too if
                      (    forth6809.asm):00554         ; output happens to be queued, since the ACIA has no control
                      (    forth6809.asm):00555         ; byte combination offering RTS-high with TX-interrupt-enabled
                      (    forth6809.asm):00556         ; simultaneously (see CR_RTSHI's comment).
                      (    forth6809.asm):00557         ; ------------------------------------------------------------
E012 BDDFF4           (    forth6809.asm):00558         RTSCHECKLO: JSR  INFILL
E015 8110             (    forth6809.asm):00559                     CMPA #INLOWATER
E017 221E             (    forth6809.asm):00560                     BHI  RTSCLODONE
E019 0DFF             (    forth6809.asm):00561                     TST  RTSSTATE
E01B 271A             (    forth6809.asm):00562                     BEQ  RTSCLODONE       ; already low - nothing to do
E01D 1A10             (    forth6809.asm):00563                     ORCC #$10              ; mask IRQ for the critical section
E01F 0FFF             (    forth6809.asm):00564                     CLR  RTSSTATE
E021 F60109           (    forth6809.asm):00565                     LDB  OUTTAIL
E024 F10108           (    forth6809.asm):00566                     CMPB OUTHEAD
E027 2707             (    forth6809.asm):00567                     BEQ  RTSCLONOTX
E029 86B5             (    forth6809.asm):00568                     LDA  #CR_RXTX
E02B B7C008           (    forth6809.asm):00569                     STA  ACIACR
E02E 2005             (    forth6809.asm):00570                     BRA  RTSCLOUNMASK
E030 8695             (    forth6809.asm):00571         RTSCLONOTX: LDA  #CR_RXON
E032 B7C008           (    forth6809.asm):00572                     STA  ACIACR
E035 1CEF             (    forth6809.asm):00573         RTSCLOUNMASK: ANDCC #$EF
E037 39               (    forth6809.asm):00574         RTSCLODONE: RTS
                      (    forth6809.asm):00575         
E038 B6C008           (    forth6809.asm):00576         IRQH:    LDA   ACIASR
E03B 8580             (    forth6809.asm):00577                  BITA  #SR_IRQ
E03D 2740             (    forth6809.asm):00578                  BEQ   IRQDONE
                      (    forth6809.asm):00579         
E03F 8501             (    forth6809.asm):00580                  BITA  #SR_RDRF
E041 271B             (    forth6809.asm):00581                  BEQ   TXCHK
                      (    forth6809.asm):00582         
E043 F60106           (    forth6809.asm):00583                  LDB   INHEAD
E046 B6C009           (    forth6809.asm):00584                  LDA   ACIADR
E049 8E010A           (    forth6809.asm):00585                  LDX   #INBUF
E04C A785             (    forth6809.asm):00586                  STA   B,X
E04E 5C               (    forth6809.asm):00587                  INCB
E04F C43F             (    forth6809.asm):00588                  ANDB  #INBUFSZ-1
E051 F10107           (    forth6809.asm):00589                  CMPB  INTAIL
E054 2729             (    forth6809.asm):00590                  BEQ   IRQDONE
E056 F70106           (    forth6809.asm):00591                  STB   INHEAD
E059 BDDFFD           (    forth6809.asm):00592                  JSR   RTSCHECKHI
