FFB5 5A               (    forth6809.asm):00468                  DECB
FFB6 26FB             (    forth6809.asm):00469                  BNE   CLRGLOB
                      (    forth6809.asm):00470         
FFB8 8E0106           (    forth6809.asm):00471                  LDX   #SERBUF
FFBB 6F80             (    forth6809.asm):00472                  CLR   ,X+
FFBD 6F84             (    forth6809.asm):00473                  CLR   ,X
                      (    forth6809.asm):00474         
FFBF 8603             (    forth6809.asm):00475                  LDA   #$03
FFC1 B7C008           (    forth6809.asm):00476                  STA   ACIACR         ; was "STA ACIA" - only correct by
                      (    forth6809.asm):00477                                        ; coincidence while ACIA and ACIACR were
                      (    forth6809.asm):00478                                        ; the same address; now genuinely distinct
FFC4 8695             (    forth6809.asm):00479                  LDA   #CR_RXON
FFC6 B7C008           (    forth6809.asm):00480                  STA   ACIACR         ; was "STA ACIA" - same fix
                      (    forth6809.asm):00481         
FFC9 7EE08C           (    forth6809.asm):00482                  JMP   COLD
                      (    forth6809.asm):00483         
FFCC 1A50             (    forth6809.asm):00484         WARM:    ORCC  #$50
FFCE 4F               (    forth6809.asm):00485                  CLRA
FFCF 1F8B             (    forth6809.asm):00486                  TFR   A,DP
FFD1 CEBD00           (    forth6809.asm):00487                  LDU   #SP0
FFD4 10CEC000         (    forth6809.asm):00488                  LDS   #RP0
FFD8 8EFFEA           (    forth6809.asm):00489                  LDX   #WARMMSG
FFDB 3610             (    forth6809.asm):00490                  PSHU  X
FFDD CC0006           (    forth6809.asm):00491                  LDD   #WARMMSGL
FFE0 3606             (    forth6809.asm):00492                  PSHU  D
FFE2 BDF71F           (    forth6809.asm):00493                  JSR   TYPE
FFE5 1CAF             (    forth6809.asm):00494                  ANDCC #$AF
FFE7 7EE0C1           (    forth6809.asm):00495                  JMP   ABORT
                      (    forth6809.asm):00496         
FFEA 20207761726D     (    forth6809.asm):00497         WARMMSG: FCC   "  warm"
     0006             (    forth6809.asm):00498         WARMMSGL EQU   *-WARMMSG
                      (    forth6809.asm):00499         
