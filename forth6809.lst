                      (    forth6809.asm):00453         
                      (    forth6809.asm):00454         ; ============================================================
                      (    forth6809.asm):00455         ; SECTION 2: INIT CODE (COLDSTRT / WARM)
                      (    forth6809.asm):00456         ; ============================================================
                      (    forth6809.asm):00457                  ORG   INITCODE       ; INITCODE is $FFA2 (was INIT/$FFA0, before that literal $FFC0)
FFA2                  (    forth6809.asm):00458         COLDSTRT:
FFA2 1A50             (    forth6809.asm):00459                  ORCC  #$50
