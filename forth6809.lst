                      (    forth6809.asm):00001         ; ============================================================
                      (    forth6809.asm):00002         ; 6809 ANS FORTH - consolidated source
                      (    forth6809.asm):00003         ; Assembled from the full design conversation.
                      (    forth6809.asm):00004         ;
                      (    forth6809.asm):00005         ; GLOBALS LAYOUT: applied. Every scratch/global cell now has a
                      (    forth6809.asm):00006         ; fixed RMB-assigned address in page zero ($0000-$00FF, DP=$00
                      (    forth6809.asm):00007         ; at reset) - see the GLOBALS section below for the full layout
                      (    forth6809.asm):00008         ; and its byte budget (256 of 256 bytes used, 0 free - the page
                      (    forth6809.asm):00009         ; is now fully packed; any future scratch cell will need to
                      (    forth6809.asm):00010         ; reuse an existing one or move a cell out of page zero).
                      (    forth6809.asm):00011         ;
                      (    forth6809.asm):00012         ; SERIAL HANDSHAKING: RTS (hardware, output) is implemented -
                      (    forth6809.asm):00013         ; IRQH/KEY toggle it based on the input ring's fill level
                      (    forth6809.asm):00014         ; against INHIWATER/INLOWATER (see SECTION 3). CTS (input) needs
                      (    forth6809.asm):00015         ; no firmware logic at all: the 6850 hardware automatically
                      (    forth6809.asm):00016         ; inhibits TDRE while CTS is deasserted, and this system's
                      (    forth6809.asm):00017         ; existing TDRE-gated transmit logic already respects that with
                      (    forth6809.asm):00018         ; no code changes. Software (XON/XOFF) handshaking remains not
                      (    forth6809.asm):00019         ; implemented - this system still neither transmits nor
                      (    forth6809.asm):00020         ; recognizes those bytes.
                      (    forth6809.asm):00021         ;
                      (    forth6809.asm):00022         ; DICTIONARY: applied (SECTION 27), 219 entries (215 original +
                      (    forth6809.asm):00023         ; DOES> + TRUE + FALSE, added in later passes - see below).
                      (    forth6809.asm):00024         ; Every primitive with a real code label now has a real ROM
                      (    forth6809.asm):00025         ; header, chained via LINK, CFA pointing directly at its code.
                      (    forth6809.asm):00026         ; Building this surfaced two real findings, not just mechanical
                      (    forth6809.asm):00027         ; work: (1) the original 1024-byte BASEDICT could not hold the
                      (    forth6809.asm):00028         ; header table (1954 bytes needed) - BASEDICT was resized to
                      (    forth6809.asm):00029         ; 2048 bytes ($E000-$E7FF), taking the space from BASECODE (then
                      (    forth6809.asm):00030         ; $E800-$FFBF, 6080 bytes, was 7104). This resize was based on
                      (    forth6809.asm):00031         ; the header-table budget alone; the actual assembled byte size
                      (    forth6809.asm):00032         ; of BASECODE's code was never measured with a real 6809
                      (    forth6809.asm):00033         ; assembler, so whether 6080 bytes was enough for all ~530
                      (    forth6809.asm):00034         ; routine labels in this file was never verified before BASECODE
                      (    forth6809.asm):00035         ; moved again (below). (2) DOES>
                      (    forth6809.asm):00036         ; initially had no corresponding code anywhere in the file -
                      (    forth6809.asm):00037         ; SETDOES and the DOES> compiling word (code label DOESGT, since
                      (    forth6809.asm):00038         ; a literal ">" is not a valid 6809 assembler label) were added
                      (    forth6809.asm):00039         ; in a follow-up pass, alongside DODOES/DOESRT0, closing that
                      (    forth6809.asm):00040         ; gap; DOESBEH was added to the GLOBALS layout to support it,
                      (    forth6809.asm):00041         ; using 2 of the page's last 3 free bytes (1 now remains). TRUE
                      (    forth6809.asm):00042         ; and FALSE were added in a still later pass: CONSTANT TRUE -1
                      (    forth6809.asm):00043         ; and CONSTANT FALSE 0, the first CONSTANT-pattern ROM-resident
                      (    forth6809.asm):00044         ; words in this system (TRUEBODY/FALSEBODY, section 26) - every
                      (    forth6809.asm):00045         ; other ROM word's CFA is a plain code label, but a CONSTANT's
                      (    forth6809.asm):00046         ; CFA is the DODOES-trampoline pattern, built by hand here with
                      (    forth6809.asm):00047         ; fixed, assemble-time addresses since there is no interactive
                      (    forth6809.asm):00048         ; CREATE/CONSTANT phase for ROM content.
                      (    forth6809.asm):00049         ;
                      (    forth6809.asm):00050         ; BASEDICT holds exactly 1973 bytes ($D83F-$DFF3), an exact,
                      (    forth6809.asm):00051         ; zero-padding fit for SECTION 27's real dictionary content.
                      (    forth6809.asm):00052         ; BASECODE ($DFF4-$FFA1) is contiguous directly above it, sized
                      (    forth6809.asm):00053         ; to a nominal 8110-byte budget. BASECODE's end lands exactly
                      (    forth6809.asm):00054         ; one byte below INITCODE's start ($FFA2) - zero gap, zero
                      (    forth6809.asm):00055         ; overlap. USROMSTRT/USROMEND, INOUT, RSTACK, DSTACK, CODETOP,
                      (    forth6809.asm):00056         ; APPCODE, APPDICT, and APPVARS are all mutually consistent, with
                      (    forth6809.asm):00057         ; no overlaps anywhere in the current memory map. See the ROM
                      (    forth6809.asm):00058         ; Size Required section of the documentation and the open-items
                      (    forth6809.asm):00059         ; checklist for real content totals and remaining margin.
                      (    forth6809.asm):00060         ;
                      (    forth6809.asm):00061         ; This file preserves the code exactly as derived and verified
                      (    forth6809.asm):00062         ; turn-by-turn in the conversation, including the corrected
                      (    forth6809.asm):00063         ; versions of every bug that was caught and fixed in place.
                      (    forth6809.asm):00064         ; SUBSTITUTE is complete but deliberately scoped to a single
                      (    forth6809.asm):00065         ; registered name/value pair, not a full table (see REPLACES).
                      (    forth6809.asm):00066         ; ENVTABLE's /HOLD and /PAD entries, and the DPHERE/CODEHERE/
                      (    forth6809.asm):00067         ; VARHERE boundary checks, remain explicitly incomplete/absent -
                      (    forth6809.asm):00068         ; see the inline notes preserved from that discussion, and the
                      (    forth6809.asm):00069         ; open-items checklist.
                      (    forth6809.asm):00070         ; ============================================================
                      (    forth6809.asm):00071         
                      (    forth6809.asm):00072         ; ------------------------------------------------------------
                      (    forth6809.asm):00073         ; MEMORY MAP
                      (    forth6809.asm):00074         ; ------------------------------------------------------------
     C100             (    forth6809.asm):00075         USROMSTRT EQU $C100     ; Usable ROM start. Beginning of the usable
                      (    forth6809.asm):00076                                  ; EPROM address range. INITCODE, BASECODE,
                      (    forth6809.asm):00077                                  ; and BASEDICT must all fall within
                      (    forth6809.asm):00078                                  ; USROMSTRT..USROMEND - see the verification
                      (    forth6809.asm):00079                                  ; note below each one's EQU.
     FFEF             (    forth6809.asm):00080         USROMEND EQU  VECTORS-1 ; Usable ROM end. Corrected: 1 before VECTORS'
                      (    forth6809.asm):00081                                  ; start ($FFEF), not one past VECTORS' end as
                      (    forth6809.asm):00082                                  ; originally defined - this is a real 16-bit
                      (    forth6809.asm):00083                                  ; address (the last byte available before the
                      (    forth6809.asm):00084                                  ; reserved vector table), usable directly in
                      (    forth6809.asm):00085                                  ; comparisons or as a memory operand, unlike
                      (    forth6809.asm):00086                                  ; the previous $10000 definition
     FFF0             (    forth6809.asm):00087         VECTORS  EQU  $FFF0
     FFA2             (    forth6809.asm):00088         INITCODE EQU  $FFA2     ; was $FFA0, before that $FFC0 - now exactly 78
                      (    forth6809.asm):00089                                  ; bytes, matching the ~78-byte COLDSTRT+WARM+
                      (    forth6809.asm):00090                                  ; WARMMSG estimate with zero margin (was 80,
                      (    forth6809.asm):00091                                  ; with 2 bytes of slack). UNRESOLVED: this is
                      (    forth6809.asm):00092                                  ; a real, pre-existing overlap with BASECODE
                      (    forth6809.asm):00093                                  ; (ends $FFBF), not something this change
                      (    forth6809.asm):00094                                  ; introduced - $FFA0 already overlapped it by
                      (    forth6809.asm):00095                                  ; 32 bytes before this change; $FFA2 overlaps
                      (    forth6809.asm):00096                                  ; by 30 bytes - reduced, not resolved. See the
                      (    forth6809.asm):00097                                  ; open-items checklist.
     DFF4             (    forth6809.asm):00098         BASECODE EQU  $DFF4     ; was $E012 - shifted down 30 bytes so its
                      (    forth6809.asm):00099                                  ; nominal end ($FFA1) lands exactly one byte
                      (    forth6809.asm):00100                                  ; below INITCODE's start ($FFA2), resolving the
                      (    forth6809.asm):00101                                  ; INITCODE/BASECODE overlap precisely: zero
                      (    forth6809.asm):00102                                  ; gap, zero overlap. Nominal size (8110 bytes)
                      (    forth6809.asm):00103                                  ; is unchanged, only the start address moved.
     D83F             (    forth6809.asm):00104         BASEDICT EQU  $D83F     ; was $D85D - shifted down the same 30 bytes as
                      (    forth6809.asm):00105                                  ; BASECODE, preserving the exact, zero-padding
                      (    forth6809.asm):00106                                  ; fit for its real 1973-byte dictionary content
                      (    forth6809.asm):00107                                  ; (SECTION 27) and staying perfectly contiguous
                      (    forth6809.asm):00108                                  ; with BASECODE's new start.
     C000             (    forth6809.asm):00109         INOUT    EQU  $C000     ; was $DF00 - moved so INOUT (256 B) sits
                      (    forth6809.asm):00110                                  ; directly below USROMSTRT ($C100), contiguous,
                      (    forth6809.asm):00111                                  ; no gap. This also resolves the INOUT portion
                      (    forth6809.asm):00112                                  ; of the collision flagged when BASEDICT moved
                      (    forth6809.asm):00113                                  ; to $D85D: INOUT no longer overlaps BASEDICT
                      (    forth6809.asm):00114                                  ; ($D85D-$E011), since $C0FF < $D85D. The
                      (    forth6809.asm):00115                                  ; DSTACK and RSTACK portions of that same
                      (    forth6809.asm):00116                                  ; collision were NOT touched by this specific
                      (    forth6809.asm):00117                                  ; change, but were resolved separately when
                      (    forth6809.asm):00118                                  ; those two regions moved (see below). This
                      (    forth6809.asm):00119                                  ; move ALSO overlapped APPCODE at the time
                      (    forth6809.asm):00120                                  ; ($7000-$D7FF then) - since resolved too, when
                      (    forth6809.asm):00121                                  ; APPCODE moved down $2000 (see below).
     C0FF             (    forth6809.asm):00122         INOUTEND EQU  INOUT+$FF
     BFFF             (    forth6809.asm):00123         RSTACK   EQU  $BFFF     ; was $BEFF - occupied range is $BD00-$BFFF
                      (    forth6809.asm):00124                                  ; (768 bytes, unchanged size). RESOLVED: once a
                      (    forth6809.asm):00125                                  ; 512-byte gap sat between this and DSTACK
                      (    forth6809.asm):00126                                  ; below; DSTACK moving up $200 closed it - now
                      (    forth6809.asm):00127                                  ; exactly contiguous, no gap
     BCFF             (    forth6809.asm):00128         DSTACK   EQU  $BCFF     ; was $BAFF - moved up $200. RESOLVED (both):
                      (    forth6809.asm):00129                                  ; occupied range is now $B900-$BCFF, which
                      (    forth6809.asm):00130                                  ; exactly matches CODETOP ($B900) as its true
                      (    forth6809.asm):00131                                  ; bottom - the 512-byte mismatch is gone - and
                      (    forth6809.asm):00132                                  ; is now exactly contiguous with RSTACK's
                      (    forth6809.asm):00133                                  ; bottom ($BD00), closing that gap too
     B900             (    forth6809.asm):00134         CODETOP  EQU  $B900     ; was $B800 - code space ceiling (data stack
                      (    forth6809.asm):00135                                  ; begins here). RESOLVED: this once no longer
                      (    forth6809.asm):00136                                  ; matched DSTACK's true occupied bottom (was
                      (    forth6809.asm):00137                                  ; $B700, a 512-byte mismatch) - now that DSTACK
                      (    forth6809.asm):00138                                  ; moved up $200 to $B900, CODETOP matches it
                      (    forth6809.asm):00139                                  ; exactly again
     7000             (    forth6809.asm):00140         APPCODE  EQU  $7000     ; was $5000 - back to its original address.
                      (    forth6809.asm):00141                                  ; RESOLVED: this once overlapped DSTACK's true
                      (    forth6809.asm):00142                                  ; range by 512 bytes ($B700-$B8FF), a direct
                      (    forth6809.asm):00143                                  ; consequence of the CODETOP/DSTACK mismatch -
                      (    forth6809.asm):00144                                  ; now that DSTACK moved and CODETOP matches it
                      (    forth6809.asm):00145                                  ; again, APPCODE's nominal range (up to
                      (    forth6809.asm):00146                                  ; CODETOP-1) no longer reaches into DSTACK
     2000             (    forth6809.asm):00147         APPDICT  EQU  $2000     ; was $015B - moved up, size unchanged (20133
                      (    forth6809.asm):00148                                  ; bytes, now $2000-$6EA4). REDUCED BUT NOT
                      (    forth6809.asm):00149                                  ; RESOLVED: still overlaps APPVARS below by 347
                      (    forth6809.asm):00150                                  ; bytes ($2000-$215A), though SIBUF/WORDBUF/
                      (    forth6809.asm):00151                                  ; TIBBUF/OUTBUF (swallowed by the previous
                      (    forth6809.asm):00152                                  ; APPDICT address) are now clear. See the
                      (    forth6809.asm):00153                                  ; open-items checklist
     021B             (    forth6809.asm):00154         APPVARS  EQU  $021B     ; grown from 256 to 8000 bytes (end now $215A,
                      (    forth6809.asm):00155                                  ; was $031A), taking the space directly from
                      (    forth6809.asm):00156                                  ; APPDICT above it; start address unchanged.
                      (    forth6809.asm):00157                                  ; That 8000-byte figure describes the original
                      (    forth6809.asm):00158                                  ; intent, not the current actual usable size -
                      (    forth6809.asm):00159                                  ; see APPVARSEND below, which now tracks
                      (    forth6809.asm):00160                                  ; APPDICT's real position instead
     1FFF             (    forth6809.asm):00161         APPVARSEND EQU APPDICT-1 ; was APPVARS+8000 ($215B) - now derives
                      (    forth6809.asm):00162                                  ; directly from wherever APPDICT actually
                      (    forth6809.asm):00163                                  ; starts, currently $1FFF (7653 bytes usable,
                      (    forth6809.asm):00164                                  ; down from the static 8000). Self-correcting:
                      (    forth6809.asm):00165                                  ; this can no longer go stale if APPDICT moves
                      (    forth6809.asm):00166                                  ; again, unlike the previous fixed-size
                      (    forth6809.asm):00167                                  ; definition. VUNUSEDW (below) is unchanged -
                      (    forth6809.asm):00168                                  ; it already computed against APPVARSEND
     01FB             (    forth6809.asm):00169         SIBUF    EQU  $01FB     ; was $0300
     01DA             (    forth6809.asm):00170         WORDBUF  EQU  $01DA     ; was $02D4
     018A             (    forth6809.asm):00171         TIBBUF   EQU  $018A     ; was $0284
     0050             (    forth6809.asm):00172         TIBBUFL  EQU  80
     0106             (    forth6809.asm):00173         SERBUF   EQU  $0106     ; was $0200 - USER0/USER1 removed entirely (see
                      (    forth6809.asm):00174                                  ; below); the 6 buffers (SERBUF's 4-byte index
                      (    forth6809.asm):00175                                  ; block, INBUF, OUTBUF, TIBBUF, WORDBUF, SIBUF)
                      (    forth6809.asm):00176                                  ; now sit contiguously right after MVSCRATCH,
                      (    forth6809.asm):00177                                  ; with no gap - this also closes a pre-existing
                      (    forth6809.asm):00178                                  ; 11-byte gap that used to sit between WORDBUF
                      (    forth6809.asm):00179                                  ; and SIBUF ($02F5-$02FF), unrelated to USER0/
                      (    forth6809.asm):00180                                  ; USER1 but caught while making this region
                      (    forth6809.asm):00181                                  ; genuinely contiguous end to end
     0106             (    forth6809.asm):00182         INHEAD   EQU  SERBUF
     0107             (    forth6809.asm):00183         INTAIL   EQU  SERBUF+1
     0108             (    forth6809.asm):00184         OUTHEAD  EQU  SERBUF+2
     0109             (    forth6809.asm):00185         OUTTAIL  EQU  SERBUF+3
     0040             (    forth6809.asm):00186         INBUFSZ  EQU  64
     0040             (    forth6809.asm):00187         OUTBUFSZ EQU  64
     010A             (    forth6809.asm):00188         INBUF    EQU  SERBUF+4
     014A             (    forth6809.asm):00189         OUTBUF   EQU  SERBUF+4+INBUFSZ
     0000             (    forth6809.asm):00190         GLOBALS  EQU  $0000
                      (    forth6809.asm):00191         
                      (    forth6809.asm):00192         ; ------------------------------------------------------------
                      (    forth6809.asm):00193         ; MVSCRATCH - three cells shared, one at a time, by routine
                      (    forth6809.asm):00194         ; families that never call each other or run concurrently in
                      (    forth6809.asm):00195         ; this single-threaded interpreter: MOVE/CMOVE/CMOVE>, FILL, and
                      (    forth6809.asm):00196         ; HOLDS (plus the single-cell multiply routine). Sharing avoids
                      (    forth6809.asm):00197         ; needing 3x the physical storage for what is provably the same
                      (    forth6809.asm):00198         ; scratch need at different times; the tradeoff is that these
                      (    forth6809.asm):00199         ; three cells use ordinary extended addressing (3-byte LDD/STD),
                      (    forth6809.asm):00200         ; not direct-page (2-byte), since page zero has no room left.
                      (    forth6809.asm):00201         ;
                      (    forth6809.asm):00202         ;   MVCNT    - MOVE/CMOVE's remaining-byte count
                      (    forth6809.asm):00203         ;     FILLCNT  EQU MVCNT   - FILL's remaining-byte count
                      (    forth6809.asm):00204         ;     HSLEN    EQU MVCNT   - HOLDS's remaining-char count
                      (    forth6809.asm):00205         ;   MVDST    - MOVE/CMOVE's destination address
                      (    forth6809.asm):00206         ;     FILLADDR EQU MVDST   - FILL's target address
                      (    forth6809.asm):00207         ;     HSADDR   EQU MVDST   - HOLDS's source address
                      (    forth6809.asm):00208         ;   MVSRC    - MOVE/CMOVE's source address
                      (    forth6809.asm):00209         ;     MRESULT  EQU MVSRC   - single-cell multiply's 16-bit result
                      (    forth6809.asm):00210         ;     FILLCHR  EQU MVSRC   - FILL's fill character (1 byte, uses
                      (    forth6809.asm):00211         ;                            MVSRC's first byte only)
                      (    forth6809.asm):00212         ; ------------------------------------------------------------
                      (    forth6809.asm):00213                  ORG   $0100
0100                  (    forth6809.asm):00214         MVCNT      RMB   2
0102                  (    forth6809.asm):00215         MVDST      RMB   2
0104                  (    forth6809.asm):00216         MVSRC      RMB   2
     0100             (    forth6809.asm):00217         FILLCNT  EQU  MVCNT
     0100             (    forth6809.asm):00218         HSLEN    EQU  MVCNT
     0102             (    forth6809.asm):00219         FILLADDR EQU  MVDST
     0102             (    forth6809.asm):00220         HSADDR   EQU  MVDST
     0104             (    forth6809.asm):00221         MRESULT  EQU  MVSRC
     0104             (    forth6809.asm):00222         FILLCHR  EQU  MVSRC
                      (    forth6809.asm):00223         
     BD00             (    forth6809.asm):00224         SP0      EQU  DSTACK+1
     C000             (    forth6809.asm):00225         RP0      EQU  RSTACK+1
                      (    forth6809.asm):00226         
                      (    forth6809.asm):00227         ; ------------------------------------------------------------
                      (    forth6809.asm):00228         ; ACIA (6850) constants - the chip sits at INOUT+8, not at the
                      (    forth6809.asm):00229         ; base of the I/O block, leaving INOUT+0..INOUT+7 free for other
                      (    forth6809.asm):00230         ; memory-mapped devices sharing this 256-byte region
                      (    forth6809.asm):00231         ; ------------------------------------------------------------
     C008             (    forth6809.asm):00232         ACIA     EQU  INOUT+8
     C008             (    forth6809.asm):00233         ACIACR   EQU  ACIA
     C008             (    forth6809.asm):00234         ACIASR   EQU  ACIA
     C009             (    forth6809.asm):00235         ACIADR   EQU  ACIA+1
     0001             (    forth6809.asm):00236         SR_RDRF  EQU  $01
     0002             (    forth6809.asm):00237         SR_TDRE  EQU  $02
     0080             (    forth6809.asm):00238         SR_IRQ   EQU  $80
     0003             (    forth6809.asm):00239         CR_RESET EQU  $03
     0095             (    forth6809.asm):00240         CR_RXON  EQU  $95
     00B5             (    forth6809.asm):00241         CR_RXTX  EQU  $B5
     00D5             (    forth6809.asm):00242         CR_RTSHI EQU  $D5     ; bits6-5=10: RTS high, TX int disabled, RX int enabled -
                      (    forth6809.asm):00243                                ; derived from CR_RXON ($95) with bits6-5 changed from
                      (    forth6809.asm):00244                                ; 00 to 10; the ACIA has no combination offering RTS
                      (    forth6809.asm):00245                                ; high AND TX interrupt enabled simultaneously (bits6-5
                      (    forth6809.asm):00246                                ; only has 00/01/10/11, and only 01 enables TX interrupt,
                      (    forth6809.asm):00247                                ; which always ties RTS low) - EMIT/IRQH's TXCHK must
                      (    forth6809.asm):00248                                ; respect this and defer transmission while RTS is high
                      (    forth6809.asm):00249         
     0030             (    forth6809.asm):00250         INHIWATER EQU 48       ; input ring fill level (of 64) at/above which RTS is
                      (    forth6809.asm):00251                                 ; asserted high, telling the remote device to pause
     0010             (    forth6809.asm):00252         INLOWATER EQU 16        ; fill level at/below which RTS is reasserted low;
                      (    forth6809.asm):00253                                  ; deliberately well below INHIWATER (hysteresis) so
                      (    forth6809.asm):00254                                  ; RTS doesn't chatter right at a single threshold
                      (    forth6809.asm):00255         
                      (    forth6809.asm):00256         ; ------------------------------------------------------------
                      (    forth6809.asm):00257         ; Flag / opcode constants
                      (    forth6809.asm):00258         ; ------------------------------------------------------------
     FFFF             (    forth6809.asm):00259         TRUEV    EQU  $FFFF
     0000             (    forth6809.asm):00260         FALSEV   EQU  $0000
     00BD             (    forth6809.asm):00261         OPJSR    EQU  $BD
     0039             (    forth6809.asm):00262         RTSOPC   EQU  $39
                      (    forth6809.asm):00263         
                      (    forth6809.asm):00264         ; ------------------------------------------------------------
                      (    forth6809.asm):00265         ; Control-flow compile-time tags
                      (    forth6809.asm):00266         ; ------------------------------------------------------------
     0001             (    forth6809.asm):00267         TAGFWD   EQU  1
     0002             (    forth6809.asm):00268         TAGBACK  EQU  2
     0003             (    forth6809.asm):00269         TAGDO    EQU  3
     0004             (    forth6809.asm):00270         TAGCASE  EQU  4
     0005             (    forth6809.asm):00271         TAGOF    EQU  5
     0006             (    forth6809.asm):00272         TAGENDOF EQU  6
                      (    forth6809.asm):00273         
                      (    forth6809.asm):00274         ; ============================================================
                      (    forth6809.asm):00275         ; GLOBALS - real layout, applied. Every scratch/state cell
                      (    forth6809.asm):00276         ; referenced across the whole build now has a fixed address
                      (    forth6809.asm):00277         ; in page zero (DP = $00 at reset, set in COLDSTRT), laid out
                      (    forth6809.asm):00278         ; in RMB order below. Total: 256 of 256 bytes used - the page
                      (    forth6809.asm):00279         ; is fully packed. (DOESBEH and RTSSTATE were added in later
                      (    forth6809.asm):00280         ; passes, after this comment was first written with 253/256;
                      (    forth6809.asm):00281         ; they used up the last 3 bytes of headroom entirely.)
                      (    forth6809.asm):00282         ;
                      (    forth6809.asm):00283         ; SNEND, which appeared in the original placeholder list
                      (    forth6809.asm):00284         ; (documented under S"/."/SLITERAL/ABORT"'s string runtime),
                      (    forth6809.asm):00285         ; was dropped here: a full pass over every reference confirmed
                      (    forth6809.asm):00286         ; it is never actually read or written anywhere - SCNT/SPTR
                      (    forth6809.asm):00287         ; alone carry that runtime. CSAVE was removed earlier (see the
                      (    forth6809.asm):00288         ; COMMA/CODECOMMA history) and was never part of this layout.
                      (    forth6809.asm):00289         ; ============================================================
                      (    forth6809.asm):00290                  ORG   $0000        ; GLOBALS page - Direct Page (DP) set to $00 at reset
0000                  (    forth6809.asm):00291         STATE      RMB   2   ; offset $00
0002                  (    forth6809.asm):00292         BASE       RMB   2   ; offset $02
0004                  (    forth6809.asm):00293         LATEST     RMB   2   ; offset $04
0006                  (    forth6809.asm):00294         DPHERE     RMB   2   ; offset $06
0008                  (    forth6809.asm):00295         CODEHERE   RMB   2   ; offset $08
000A                  (    forth6809.asm):00296         VARHERE    RMB   2   ; offset $0A
