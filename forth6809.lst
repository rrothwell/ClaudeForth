                      (    forth6809.asm):04775                                   ; COLD to initialize LATEST, and asserted in the
                      (    forth6809.asm):04776                                   ; SECTION 27 header comment below, but never
                      (    forth6809.asm):04777                                   ; actually defined anywhere until now: an
                      (    forth6809.asm):04778                                   ; undefined-symbol bug, not a placeholder
                      (    forth6809.asm):04779         
                      (    forth6809.asm):04780         ; ------------------------------------------------------------
                      (    forth6809.asm):04781         ; TRUE / FALSE - CONSTANT TRUE -1 / CONSTANT FALSE 0. The first
                      (    forth6809.asm):04782         ; CONSTANT-pattern ROM-resident words in this system: every
                      (    forth6809.asm):04783         ; other ROM word's CFA is a plain code label (a real routine),
                      (    forth6809.asm):04784         ; but a CONSTANT's CFA is the DODOES trampoline pattern (JSR
                      (    forth6809.asm):04785         ; DODOES + FDB ATSIGN + FDB <value-cell-address>), matching
                      (    forth6809.asm):04786         ; exactly what interactive CONSTANT compiles at runtime - the
                      (    forth6809.asm):04787         ; only difference is the value-cell address is a fixed, known-
                      (    forth6809.asm):04788         ; at-assemble-time label here (TRUEVAL/FALSEVAL) rather than a
                      (    forth6809.asm):04789         ; CODEHERE snapshot captured dynamically. DODOES pushes the
                      (    forth6809.asm):04790         ; value stored at the PFA field (the address in TRUEVAL/
                      (    forth6809.asm):04791         ; FALSEVAL); ATSIGN then fetches through that address, yielding
                      (    forth6809.asm):04792         ; the actual -1 / 0 - the same indirection interactive CONSTANT
                      (    forth6809.asm):04793         ; relies on, just with fixed addresses instead of a runtime one.
                      (    forth6809.asm):04794         ; ------------------------------------------------------------
FF72 BDE177           (    forth6809.asm):04795         TRUEBODY:  JSR   DODOES
FF75 E304             (    forth6809.asm):04796                    FDB   ATSIGN
FF77 FF79             (    forth6809.asm):04797                    FDB   TRUEVAL
FF79 FFFF             (    forth6809.asm):04798         TRUEVAL:   FDB   -1
                      (    forth6809.asm):04799         
FF7B BDE177           (    forth6809.asm):04800         FALSEBODY: JSR   DODOES
FF7E E304             (    forth6809.asm):04801                    FDB   ATSIGN
FF80 FF82             (    forth6809.asm):04802                    FDB   FALSEVAL
FF82 0000             (    forth6809.asm):04803         FALSEVAL:  FDB   0
                      (    forth6809.asm):04804         
                      (    forth6809.asm):04805         ; Verify no collision with init code,
                      (    forth6809.asm):04806         ; value should match ORG INITCODE.
     FF84             (    forth6809.asm):04807         BASECODEEND  EQU   *
     1F90             (    forth6809.asm):04808         BASECODESIZE EQU   BASECODEEND-BASECODE
                      (    forth6809.asm):04809         
                      (    forth6809.asm):04810         ; ============================================================
                      (    forth6809.asm):04811         ; SECTION 27: FORTH DICTIONARY (ROM base dictionary headers)
                      (    forth6809.asm):04812         ; Every primitive word in the Glossary gets a real header here,
                      (    forth6809.asm):04813         ; chained via LINK, living in BASEDICT ($D85D-$E011, an exact fit
                      (    forth6809.asm):04814         ; for this dictionary's 1973 bytes - was $E000-$E7FF). CFA points
                      (    forth6809.asm):04815         ; directly at each primitive's own code label for almost every
                      (    forth6809.asm):04816         ; entry - these are raw code entries, not DODOES trampolines, so
                      (    forth6809.asm):04817         ; CFA = the label itself. The two exceptions are TRUE and FALSE
                      (    forth6809.asm):04818         ; (added in a later pass, chain's newest entries): their CFA is
                      (    forth6809.asm):04819         ; the DODOES-trampoline pattern instead, matching what CONSTANT
                      (    forth6809.asm):04820         ; would compile interactively - see TRUEBODY/FALSEBODY, section
                      (    forth6809.asm):04821         ; 26, for why and how.
                      (    forth6809.asm):04822         ;
                      (    forth6809.asm):04823         ; DOES> is included (H_DOESGT) - added in a follow-up pass after
                      (    forth6809.asm):04824         ; the original 214-entry generation flagged it as missing, then
                      (    forth6809.asm):04825         ; moved again so it sits immediately after CREATE in the chain
                      (    forth6809.asm):04826         ; (H_CREATE -> H_DOESGT -> H_VARIABLE) rather than at the chain's
                      (    forth6809.asm):04827         ; newest end, since the two words are tightly coupled and read
                      (    forth6809.asm):04828         ; better adjacent. SETDOES (the runtime it compiles a call to)
                      (    forth6809.asm):04829         ; lives beside DODOES/DOESRT0; DOESGT is DOES>'s code label,
                      (    forth6809.asm):04830         ; since a literal ">" is not valid in a 6809 assembler label.
                      (    forth6809.asm):04831         ;
                      (    forth6809.asm):04832         ; ABORT and QUIT already have hand-built headers (ABORTHDR/
                      (    forth6809.asm):04833         ; QUITHDR, section 26) and are NOT duplicated here. This chain
                      (    forth6809.asm):04834         ; is spliced in below them: QUITHDR -> ABORTHDR -> (newest entry
                      (    forth6809.asm):04835         ; below) -> ... -> (oldest entry) -> 0. BASELATEST remains QUITHDR.
                      (    forth6809.asm):04836         ;
                      (    forth6809.asm):04837         ; ABORTHDR's LINK field, a placeholder 0 since it was first built,
                      (    forth6809.asm):04838         ; is resolved here: it now points to this chain's newest entry.
                      (    forth6809.asm):04839         ;
                      (    forth6809.asm):04840         ; Names containing a literal double-quote (S", .", ABORT") have
                      (    forth6809.asm):04841         ; that character split into a standalone FCB $22 rather than
                      (    forth6809.asm):04842         ; escaped inside FCC - see emit_name's comment for why.
                      (    forth6809.asm):04843         ; ============================================================
